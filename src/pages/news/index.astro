---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function fmt(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title="News" description="Latest news and updates from the CAL DMRadio collaboration.">

  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Updates</span>
      <h1>News</h1>
      <p class="desc">Announcements, milestones, and updates from the CAL DMRadio collaboration.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- Search -->
      <div style="margin-bottom:2.5rem;">
        <div class="search-wrap">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input
            type="search"
            id="news-search"
            class="search-input"
            placeholder="Search news..."
            aria-label="Search news"
          />
        </div>
      </div>

      <!-- Posts -->
      <div class="grid-3" id="news-grid">
        {posts.map(post => (
          <a
            href={`${base}/news/${post.id}/`}
            class="card news-card"
            style="text-decoration:none;"
            data-title={post.data.title.toLowerCase()}
            data-summary={post.data.summary.toLowerCase()}
            data-tags={post.data.tags?.join(' ').toLowerCase() ?? ''}
          >
            <div class="news-date">{fmt(post.data.date)}</div>
            <h3>{post.data.title}</h3>
            <p>{post.data.summary}</p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div style="display:flex;flex-wrap:wrap;gap:0.35rem;margin-top:0.75rem;">
                {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
              </div>
            )}
            <span class="read-more">Read more &rarr;</span>
          </a>
        ))}
      </div>

      <!-- Empty state -->
      <p id="news-empty" style="display:none;color:var(--gray-400);margin-top:2rem;">No posts match your search.</p>

    </div>
  </section>

</Layout>

<script>
  const input = document.getElementById('news-search') as HTMLInputElement;
  const grid  = document.getElementById('news-grid');
  const empty = document.getElementById('news-empty');

  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    let visible = 0;
    grid?.querySelectorAll<HTMLElement>('.card').forEach(card => {
      const text = [card.dataset.title, card.dataset.summary, card.dataset.tags].join(' ');
      const show = !q || text.includes(q);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
  });
</script>
