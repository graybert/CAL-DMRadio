---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const recentNews = allNews
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function fmt(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Layout title="CAL DMRadio" description="Searching for ultralight dark matter at UC Berkeley.">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="eyebrow">UC Berkeley &middot; Dark Matter Experiment</span>
      <h1>Listening for<br>Dark Matter</h1>
      <p class="hero-desc">
        CAL DMRadio uses quantum-limited electromagnetic receivers to search for ultralight
        dark matter &mdash; axions and axion-like particles &mdash; across an unexplored mass
        range at the boundary of quantum and classical noise.
      </p>
      <div class="hero-actions">
        <a href={`${base}/experiment/`} class="btn btn-primary">About the Experiment</a>
        <a href={`${base}/dark-matter/`} class="btn btn-secondary">Dark Matter Science</a>
      </div>
      <div class="hero-stat-row">
        <div class="hero-stat">
          <div class="num">10<sup style="font-size:0.9rem">&#8722;22</sup>&ndash;10<sup style="font-size:0.9rem">&#8722;18</sup> eV</div>
          <div class="label">Target axion mass range</div>
        </div>
        <div class="hero-stat">
          <div class="num">SQL</div>
          <div class="label">Quantum-limited sensitivity</div>
        </div>
        <div class="hero-stat">
          <div class="num">Toroidal LC</div>
          <div class="label">Resonator geometry</div>
        </div>
        <div class="hero-stat">
          <div class="num">UC Berkeley</div>
          <div class="label">Home institution</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <span class="section-label">The Experiment</span>
          <h2 style="margin-bottom:1.25rem;">Probing the Dark Side of the Universe</h2>
          <p style="margin-bottom:1.25rem;">
            DMRadio is a lumped-element resonator experiment that searches for the weak electromagnetic
            signal predicted from axion dark matter coupling in the presence of a strong static magnetic
            field. The toroidal pickup geometry suppresses background fields while maximizing sensitivity
            to the axion signal.
          </p>
          <p style="margin-bottom:1.25rem;">
            [Replace this paragraph with a 2&ndash;3 sentence overview from the DMRadio proposal or
            experiment paper. Describe the SQUID amplifier chain, operating temperature, and target sensitivity
            relative to the DFSZ/KSVZ axion models.]
          </p>
          <p style="margin-bottom:2rem;">
            [Second paragraph: what makes DMRadio unique &mdash; mass range, detection technique,
            sensitivity to axion-photon coupling &mdash; compared to cavity-based searches like ADMX.]
          </p>
          <a href={`${base}/experiment/`} class="btn btn-secondary">Full experiment description &rarr;</a>
        </div>
        <div>
          <div class="diagram-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p><strong>Experiment schematic</strong></p>
            <p>Replace with detector diagram or photo</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider">

  <!-- Three pillars -->
  <section class="section">
    <div class="container">
      <h2 style="margin-bottom:2.5rem;">Explore DMRadio</h2>
      <div class="grid-3">
        <a href={`${base}/dark-matter/`} class="card" style="text-decoration:none;">
          <div style="font-size:1.75rem;margin-bottom:1rem;">&#127756;</div>
          <h3 style="margin-bottom:0.5rem;">Dark Matter Science</h3>
          <p style="font-size:0.9rem;">Why we believe dark matter exists, the case for axions, and how electrodynamic detectors probe this parameter space.</p>
        </a>
        <a href={`${base}/publications/`} class="card" style="text-decoration:none;">
          <div style="font-size:1.75rem;margin-bottom:1rem;">&#128196;</div>
          <h3 style="margin-bottom:0.5rem;">Publications</h3>
          <p style="font-size:0.9rem;">Papers, theses, and conference proceedings from the DMRadio collaboration.</p>
        </a>
        <a href={`${base}/opportunities/`} class="card" style="text-decoration:none;">
          <div style="font-size:1.75rem;margin-bottom:1rem;">&#128300;</div>
          <h3 style="margin-bottom:0.5rem;">Join the Lab</h3>
          <p style="font-size:0.9rem;">Open positions for graduate students, postdocs, and undergraduates interested in dark matter detection.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent News -->
  {recentNews.length > 0 && (
    <>
      <hr class="divider">
      <section class="section">
        <div class="container">
          <div class="section-header">
            <h2>Latest News</h2>
            <a href={`${base}/news/`} class="btn btn-secondary" style="font-size:0.875rem;">All news &rarr;</a>
          </div>
          <div class="grid-3">
            {recentNews.map(post => (
              <a href={`${base}/news/${post.id}/`} class="card news-card" style="text-decoration:none;">
                <div class="news-date">{fmt(post.data.date)}</div>
                <h3>{post.data.title}</h3>
                <p>{post.data.summary}</p>
                <span class="read-more">Read more &rarr;</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    </>
  )}

</Layout>
