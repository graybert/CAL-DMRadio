---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CAL-Pathfinder',
  description = 'CAL-Pathfinder searches for ultralight dark matter — axions and axion-like particles — using quantum-limited electromagnetic receivers at UC Berkeley.',
} = Astro.props;

const pageTitle = title === 'CAL-Pathfinder' ? title : `${title} | CAL-Pathfinder`;
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // '/CAL-DMRadio' or ''
const pathname = Astro.url.pathname;

function isActive(path: string) {
  if (path === '/') return pathname === base + '/' || pathname === base;
  return pathname.startsWith(base + path);
}

const nav = [
  { label: 'Dark Matter',        href: '/dark-matter/' },
  { label: 'Gravitational Waves', href: '/gravitational-waves/' },
  { label: 'Experiment',         href: '/experiment/' },
  { label: 'Talks',              href: '/talks/' },
  { label: 'Publications',       href: '/publications/' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" href={`${base}/favicon.ico`} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <!-- OG -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>

    <!-- ── Header ── -->
    <header class="site-header">
      <nav class="nav-inner">
        <a href={`${base}/`} class="nav-logo">CAL-<span>Pathfinder</span></a>

        <ul class="nav-links">
          {nav.map(({ label, href, cta }) => (
            <li>
              <a
                href={`${base}${href}`}
                class:list={[{ active: isActive(href), 'nav-cta': cta }]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>

        <button class="nav-hamburger" id="hamburger" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
      </nav>

      <!-- Mobile menu -->
      <nav class="nav-mobile" id="nav-mobile">
        <a href={`${base}/`}>Home</a>
        {nav.map(({ label, href, cta }) => (
          <a href={`${base}${href}`} class:list={[{ cta }]}>{label}</a>
        ))}
      </nav>
    </header>

    <!-- ── Main ── -->
    <main>
      <slot />
    </main>

    <!-- ── Footer ── -->
    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <div class="footer-brand">CAL-Pathfinder</div>
            <p class="footer-desc">
              A UC Berkeley experiment searching for ultralight dark matter using
              quantum-limited electromagnetic receivers.
            </p>
          </div>
          <div>
            <div class="footer-heading">Experiment</div>
            <ul class="footer-links">
              <li><a href={`${base}/experiment/`}>How It Works</a></li>
              <li><a href={`${base}/dark-matter/`}>Dark Matter Context</a></li>
              <li><a href={`${base}/publications/`}>Publications</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-heading">More</div>
            <ul class="footer-links">
              <li><a href={`${base}/talks/`}>Talks</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span class="footer-copy">&copy; {new Date().getFullYear()} CAL-Pathfinder Collaboration · UC Berkeley</span>
          <span class="footer-copy">Department of Physics</span>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('hamburger');
      const menu = document.getElementById('nav-mobile');
      btn?.addEventListener('click', () => menu?.classList.toggle('open'));
      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!btn?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
          menu?.classList.remove('open');
        }
      });
    </script>

  </body>
</html>
